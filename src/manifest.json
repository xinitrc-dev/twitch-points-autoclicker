{
  "manifest_version": 3,
  "name": "Twitch Channel Points Autoclicker (Lite)",
  "description": "Automatically claims 'Channel Points' on Twitch",
  "version": "1.4",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["arrive-2.4.1.min.js", "twitch-clicker.js"],
      "run_at" : "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}